#!/usr/bin/env python3
"""Thin CLI shim that delegates to the canonical package entrypoint."""
import os
import sys

# Ensure local src package is importable when running from the repo checkout.
REPO_ROOT = os.path.abspath(os.path.dirname(__file__))
SRC_DIR = os.path.join(REPO_ROOT, "src")
if SRC_DIR not in sys.path:
    sys.path.insert(0, SRC_DIR)

from copyclip.__main__ import main

if __name__ == "__main__":
    main()
